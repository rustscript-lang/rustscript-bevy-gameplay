use bevy;

let size: int = bevy::Gomoku::board_size();
let in_bounds: bool = move_x >= 0 && move_x < size && move_y >= 0 && move_y < size;
let known_player: bool = player == 1 || player == 2;
let empty_point: bool = if in_bounds => {
    bevy::Gomoku::cell(move_x, move_y) == 0
} else => {
    false
};
let legal: bool = in_bounds && known_player && empty_point;
let mut placed: bool = false;
let place_step: bool = if legal => {
    placed = bevy::Gomoku::set_cell(move_x, move_y, player);
    true
} else => {
    false
};

let mut winner: int = 0;
let mut dir: int = 0;
while legal && dir < 4 {
    let dx: int = if dir == 0 => {
        1
    } else => {
        if dir == 1 => {
            0
        } else => {
            1
        }
    };
    let dy: int = if dir == 0 => {
        0
    } else => {
        if dir == 1 => {
            1
        } else => {
            if dir == 2 => {
                1
            } else => {
                -1
            }
        }
    };

    let mut total: int = 1;
    let mut x: int = move_x + dx;
    let mut y: int = move_y + dy;
    while bevy::Gomoku::cell(x, y) == player {
        total = total + 1;
        x = x + dx;
        y = y + dy;
    }

    x = move_x - dx;
    y = move_y - dy;
    while bevy::Gomoku::cell(x, y) == player {
        total = total + 1;
        x = x - dx;
        y = y - dy;
    }

    let marked: bool = if total >= 5 => {
        winner = player;
        true
    } else => {
        false
    };
    dir = dir + 1;
}

let mut empty_count: int = 0;
let mut scan_y: int = 0;
while scan_y < size {
    let mut scan_x: int = 0;
    while scan_x < size {
        let counted: bool = if bevy::Gomoku::cell(scan_x, scan_y) == 0 => {
            empty_count = empty_count + 1;
            true
        } else => {
            false
        };
        scan_x = scan_x + 1;
    }
    scan_y = scan_y + 1;
}

let draw: bool = legal && winner == 0 && empty_count == 0;
let published: bool = bevy::Gomoku::set_move_result(legal, winner, draw);
legal;
