use bevy;

fn line_length(x: int, y: int, dx: int, dy: int, stone: int) -> int {
    let mut total = 1;
    let mut px = x + dx;
    let mut py = y + dy;
    while bevy::Gomoku::cell(px, py) == stone {
        total = total + 1;
        px = px + dx;
        py = py + dy;
    }
    px = x - dx;
    py = y - dy;
    while bevy::Gomoku::cell(px, py) == stone {
        total = total + 1;
        px = px - dx;
        py = py - dy;
    }
    total
}

fn has_five(x: int, y: int, stone: int) -> bool {
    line_length(x, y, 1, 0, stone) >= 5 ||
        line_length(x, y, 0, 1, stone) >= 5 ||
        line_length(x, y, 1, 1, stone) >= 5 ||
        line_length(x, y, 1, -1, stone) >= 5
}

fn board_full(size: int) -> bool {
    let mut empty = 0;
    let mut y = 0;
    while y < size {
        let mut x = 0;
        while x < size {
            if bevy::Gomoku::cell(x, y) == 0 {
                empty = empty + 1;
            }
            x = x + 1;
        }
        y = y + 1;
    }
    empty == 0
}

let size: int = bevy::Gomoku::board_size();
let in_bounds = move_x >= 0 && move_x < size && move_y >= 0 && move_y < size;
let known_player = player == 1 || player == 2;
let legal = in_bounds && known_player && bevy::Gomoku::cell(move_x, move_y) == 0;
let mut winner = 0;

if legal {
    bevy::Gomoku::set_cell(move_x, move_y, player);
    if has_five(move_x, move_y, player) {
        winner = player;
    }
}

let draw = legal && winner == 0 && board_full(size);
bevy::Gomoku::set_move_result(legal, winner, draw);
legal;
