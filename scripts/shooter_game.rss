let wave: bool = bevy::Shooter::spawn_enemy("weaver", 28, "wave", 120, 520);
let tank: bool = bevy::Shooter::spawn_enemy("tank", 65, "straight", 210, 470);

let bullets: bool = bevy::Shooter::spawn_reward("bullets", 1, -120, -220);
