use bevy;

fn abs_int(value: int) -> int {
    if value < 0 => { -value } else => { value }
}

fn in_bounds(x: int, y: int) -> bool {
    x >= 0 && x < 9 && y >= 0 && y < 10
}

fn in_palace(side: int, x: int, y: int) -> bool {
    x >= 3 && x <= 5 && if side == 1 => { y >= 7 && y <= 9 } else => { y >= 0 && y <= 2 }
}

fn count_between(fx: int, fy: int, tx: int, ty: int) -> int {
    let mut count = 0;
    if fx == tx || fy == ty {
        let step_x = if tx > fx => { 1 } else => { if tx < fx => { -1 } else => { 0 } };
        let step_y = if ty > fy => { 1 } else => { if ty < fy => { -1 } else => { 0 } };
        let mut x = fx + step_x;
        let mut y = fy + step_y;
        while x != tx || y != ty {
            if bevy::Xiangqi::cell(x, y) != 0 {
                count = count + 1;
            }
            x = x + step_x;
            y = y + step_y;
        }
    }
    count
}

fn pseudo_legal(side: int, fx: int, fy: int, tx: int, ty: int) -> bool {
    let mut valid = false;
    if in_bounds(fx, fy) && in_bounds(tx, ty) && (fx != tx || fy != ty) {
        let piece: int = bevy::Xiangqi::cell(fx, fy);
        let target: int = bevy::Xiangqi::cell(tx, ty);
        if piece * side > 0 && target * side <= 0 {
            let kind = abs_int(piece);
            let dx = tx - fx;
            let dy = ty - fy;
            let ax = abs_int(dx);
            let ay = abs_int(dy);
            if kind == 1 {
                let step = ax + ay == 1 && in_palace(side, tx, ty);
                let flying = fx == tx && target == -side && count_between(fx, fy, tx, ty) == 0;
                valid = step || flying;
            } else {
                if kind == 2 {
                    valid = ax == 1 && ay == 1 && in_palace(side, tx, ty);
                } else {
                    if kind == 3 {
                        let own_half = if side == 1 => { ty >= 5 } else => { ty <= 4 };
                        valid = ax == 2 && ay == 2 && own_half &&
                            bevy::Xiangqi::cell(fx + dx / 2, fy + dy / 2) == 0;
                    } else {
                        if kind == 4 {
                            let leg_x = if ax == 2 => { fx + dx / 2 } else => { fx };
                            let leg_y = if ay == 2 => { fy + dy / 2 } else => { fy };
                            valid = ((ax == 2 && ay == 1) || (ax == 1 && ay == 2)) &&
                                bevy::Xiangqi::cell(leg_x, leg_y) == 0;
                        } else {
                            if kind == 5 {
                                valid = (fx == tx || fy == ty) && count_between(fx, fy, tx, ty) == 0;
                            } else {
                                if kind == 6 {
                                    let line = fx == tx || fy == ty;
                                    let screens = count_between(fx, fy, tx, ty);
                                    valid = line && if target == 0 => { screens == 0 } else => { screens == 1 };
                                } else {
                                    if kind == 7 {
                                        let forward = if side == 1 => { dy == -1 } else => { dy == 1 };
                                        let crossed = if side == 1 => { fy <= 4 } else => { fy >= 5 };
                                        valid = (dx == 0 && forward) || (crossed && ay == 0 && ax == 1);
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
    valid
}

fn find_general(side: int) -> [int] {
    let mut result: [int] = [-1, -1];
    let mut y = 0;
    while y < 10 {
        let mut x = 0;
        while x < 9 {
            if bevy::Xiangqi::cell(x, y) == side {
                result[0] = x;
                result[1] = y;
            }
            x = x + 1;
        }
        y = y + 1;
    }
    result
}

fn is_attacked(x: int, y: int, by_side: int) -> bool {
    let mut attacked = false;
    let mut fy = 0;
    while !attacked && fy < 10 {
        let mut fx = 0;
        while !attacked && fx < 9 {
            if bevy::Xiangqi::cell(fx, fy) * by_side > 0 && pseudo_legal(by_side, fx, fy, x, y) {
                attacked = true;
            }
            fx = fx + 1;
        }
        fy = fy + 1;
    }
    attacked
}

fn legal_after_trial(side: int, fx: int, fy: int, tx: int, ty: int) -> bool {
    let mut legal = pseudo_legal(side, fx, fy, tx, ty);
    if legal {
        let piece: int = bevy::Xiangqi::cell(fx, fy);
        let target: int = bevy::Xiangqi::cell(tx, ty);
        bevy::Xiangqi::set_cell(fx, fy, 0);
        bevy::Xiangqi::set_cell(tx, ty, piece);
        let general = find_general(side);
        let gx = general[0].copy();
        let gy = general[1].copy();
        legal = gx >= 0 && !is_attacked(gx, gy, -side);
        bevy::Xiangqi::set_cell(fx, fy, piece);
        bevy::Xiangqi::set_cell(tx, ty, target);
    }
    legal
}

fn base_value(kind: int) -> int {
    if kind == 1 => { 600000 } else => {
        if kind == 5 => { 9000 } else => {
            if kind == 6 => { 4500 } else => {
                if kind == 4 => { 4000 } else => {
                    if kind == 2 || kind == 3 => { 2000 } else => {
                        if kind == 7 => { 1000 } else => { 0 }
                    }
                }
            }
        }
    }
}

// Lightweight XQWLight-style material and piece-square evaluation.
fn piece_value(piece: int, x: int, y: int) -> int {
    let side = if piece > 0 => { 1 } else => { -1 };
    let kind = abs_int(piece);
    let center = 4 - abs_int(x - 4);
    let advance = if side == 1 => { 9 - y } else => { y };
    let mut value = base_value(kind);
    if kind == 7 {
        value = value + advance * 70 + center * 25;
        let crossed = if side == 1 => { y <= 4 } else => { y >= 5 };
        if crossed {
            value = value + 350;
        }
    } else {
        if kind == 4 {
            value = value + center * 55 + (4 - abs_int(y - 4)) * 20;
        } else {
            if kind == 5 || kind == 6 {
                value = value + center * 25 + advance * 8;
            } else {
                if kind == 2 || kind == 3 {
                    value = value + 80;
                }
            }
        }
    }
    value
}

fn evaluate(side: int) -> int {
    let mut score = 0;
    let mut y = 0;
    while y < 10 {
        let mut x = 0;
        while x < 9 {
            let piece: int = bevy::Xiangqi::cell(x, y);
            if piece != 0 {
                let value = piece_value(piece, x, y);
                if piece * side > 0 {
                    score = score + value;
                } else {
                    score = score - value;
                }
            }
            x = x + 1;
        }
        y = y + 1;
    }
    score
}

// Extends a leaf through the best legal capture to reduce horizon errors.
fn capture_extension(side: int, stand_pat: int) -> int {
    let mut best = stand_pat;
    let mut fy = 0;
    while fy < 10 {
        let mut fx = 0;
        while fx < 9 {
            if bevy::Xiangqi::cell(fx, fy) * side > 0 {
                let mut ty = 0;
                while ty < 10 {
                    let mut tx = 0;
                    while tx < 9 {
                        let target: int = bevy::Xiangqi::cell(tx, ty);
                        if target * side < 0 && legal_after_trial(side, fx, fy, tx, ty) {
                            let piece: int = bevy::Xiangqi::cell(fx, fy);
                            bevy::Xiangqi::set_cell(fx, fy, 0);
                            bevy::Xiangqi::set_cell(tx, ty, piece);
                            let score = if target == -side => { 900000000 } else => { evaluate(side) };
                            bevy::Xiangqi::set_cell(fx, fy, piece);
                            bevy::Xiangqi::set_cell(tx, ty, target);
                            if score > best {
                                best = score;
                            }
                        }
                        tx = tx + 1;
                    }
                    ty = ty + 1;
                }
            }
            fx = fx + 1;
        }
        fy = fy + 1;
    }
    best
}

let opponent: int = -ai_player;
let mut top_fx: [int] = [-1, -1, -1, -1, -1, -1];
let mut top_fy: [int] = [-1, -1, -1, -1, -1, -1];
let mut top_tx: [int] = [-1, -1, -1, -1, -1, -1];
let mut top_ty: [int] = [-1, -1, -1, -1, -1, -1];
let mut top_score: [int] = [-2000000000, -2000000000, -2000000000, -2000000000, -2000000000, -2000000000];

// Move ordering: legal generation, captures, checks, then positional value.
let mut fy = 0;
while fy < 10 {
    let mut fx = 0;
    while fx < 9 {
        if bevy::Xiangqi::cell(fx, fy) * ai_player > 0 {
            let mut ty = 0;
            while ty < 10 {
                let mut tx = 0;
                while tx < 9 {
                    if legal_after_trial(ai_player, fx, fy, tx, ty) {
                        let piece: int = bevy::Xiangqi::cell(fx, fy);
                        let target: int = bevy::Xiangqi::cell(tx, ty);
                        bevy::Xiangqi::set_cell(fx, fy, 0);
                        bevy::Xiangqi::set_cell(tx, ty, piece);
                        let mut score = evaluate(ai_player) + base_value(abs_int(target)) * 2;
                        if target == opponent {
                            score = 1900000000;
                        } else {
                            let enemy_general = find_general(opponent);
                            let ex = enemy_general[0].copy();
                            let ey = enemy_general[1].copy();
                            if ex >= 0 && is_attacked(ex, ey, ai_player) {
                                score = score + 700;
                            }
                        }
                        bevy::Xiangqi::set_cell(fx, fy, piece);
                        bevy::Xiangqi::set_cell(tx, ty, target);

                        let mut insert = 0;
                        while insert < 6 && score <= top_score[insert].copy() {
                            insert = insert + 1;
                        }
                        if insert < 6 {
                            let mut shift = 5;
                            while shift > insert {
                                top_score[shift] = top_score[shift - 1].copy();
                                top_fx[shift] = top_fx[shift - 1].copy();
                                top_fy[shift] = top_fy[shift - 1].copy();
                                top_tx[shift] = top_tx[shift - 1].copy();
                                top_ty[shift] = top_ty[shift - 1].copy();
                                shift = shift - 1;
                            }
                            top_score[insert] = score;
                            top_fx[insert] = fx;
                            top_fy[insert] = fy;
                            top_tx[insert] = tx;
                            top_ty[insert] = ty;
                        }
                    }
                    tx = tx + 1;
                }
                ty = ty + 1;
            }
        }
        fx = fx + 1;
    }
    fy = fy + 1;
}

let mut best_fx = -1;
let mut best_fy = -1;
let mut best_tx = -1;
let mut best_ty = -1;
let mut best_score = -2000000000;
let mut candidate = 0;
while candidate < 6 && top_fx[candidate].copy() >= 0 {
    let fx = top_fx[candidate].copy();
    let fy = top_fy[candidate].copy();
    let tx = top_tx[candidate].copy();
    let ty = top_ty[candidate].copy();
    let piece: int = bevy::Xiangqi::cell(fx, fy);
    let target: int = bevy::Xiangqi::cell(tx, ty);
    bevy::Xiangqi::set_cell(fx, fy, 0);
    bevy::Xiangqi::set_cell(tx, ty, piece);

    let mut searched = 900000000;
    if target != opponent {
        let mut reply_found = false;
        let mut cutoff = false;
        let mut rfy = 0;
        while !cutoff && rfy < 10 {
            let mut rfx = 0;
            while !cutoff && rfx < 9 {
                if bevy::Xiangqi::cell(rfx, rfy) * opponent > 0 {
                    let mut rty = 0;
                    while !cutoff && rty < 10 {
                        let mut rtx = 0;
                        while !cutoff && rtx < 9 {
                            if legal_after_trial(opponent, rfx, rfy, rtx, rty) {
                                reply_found = true;
                                let reply_piece: int = bevy::Xiangqi::cell(rfx, rfy);
                                let reply_target: int = bevy::Xiangqi::cell(rtx, rty);
                                bevy::Xiangqi::set_cell(rfx, rfy, 0);
                                bevy::Xiangqi::set_cell(rtx, rty, reply_piece);
                                let reply_score = if reply_target == ai_player => {
                                    -900000000
                                } else => {
                                    let stand_pat = evaluate(ai_player);
                                    capture_extension(ai_player, stand_pat)
                                };
                                bevy::Xiangqi::set_cell(rfx, rfy, reply_piece);
                                bevy::Xiangqi::set_cell(rtx, rty, reply_target);
                                if reply_score < searched {
                                    searched = reply_score;
                                }
                                if searched <= best_score {
                                    cutoff = true;
                                }
                            }
                            rtx = rtx + 1;
                        }
                        rty = rty + 1;
                    }
                }
                rfx = rfx + 1;
            }
            rfy = rfy + 1;
        }
        if !reply_found {
            searched = 850000000;
        }
    }

    bevy::Xiangqi::set_cell(fx, fy, piece);
    bevy::Xiangqi::set_cell(tx, ty, target);
    let final_score = searched + top_score[candidate].copy() / 100;
    if final_score > best_score {
        best_score = final_score;
        best_fx = fx;
        best_fy = fy;
        best_tx = tx;
        best_ty = ty;
    }
    candidate = candidate + 1;
}

bevy::Xiangqi::set_ai_move(best_fx, best_fy, best_tx, best_ty);
best_score;
