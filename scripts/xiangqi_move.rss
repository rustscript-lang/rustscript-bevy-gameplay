use bevy;

let width: int = bevy::Xiangqi::board_width();
let height: int = bevy::Xiangqi::board_height();
let in_bounds: bool = from_x >= 0 && from_x < width && from_y >= 0 && from_y < height
    && to_x >= 0 && to_x < width && to_y >= 0 && to_y < height;
let mut piece: int = 0;
let piece_step: bool = if in_bounds => {
    piece = bevy::Xiangqi::cell(from_x, from_y);
    true
} else => {
    false
};
let mut target: int = 99;
let target_step: bool = if in_bounds => {
    target = bevy::Xiangqi::cell(to_x, to_y);
    true
} else => {
    false
};
let own_piece: bool = piece * player > 0;
let target_ok: bool = target == 0 || target * player < 0;
let mut abs_piece: int = piece;
let abs_step: bool = if abs_piece < 0 => {
    abs_piece = 0 - abs_piece;
    true
} else => {
    false
};
let dx_raw: int = to_x - from_x;
let dy_raw: int = to_y - from_y;
let mut abs_dx: int = dx_raw;
let abs_dx_step: bool = if abs_dx < 0 => {
    abs_dx = 0 - abs_dx;
    true
} else => {
    false
};
let mut abs_dy: int = dy_raw;
let abs_dy_step: bool = if abs_dy < 0 => {
    abs_dy = 0 - abs_dy;
    true
} else => {
    false
};

let same_file: bool = from_x == to_x;
let same_rank: bool = from_y == to_y;
let mut step_x: int = 0;
let step_x_setup: bool = if to_x > from_x => {
    step_x = 1;
    true
} else => {
    if to_x < from_x => {
        step_x = -1;
        true
    } else => {
        false
    }
};
let mut step_y: int = 0;
let step_y_setup: bool = if to_y > from_y => {
    step_y = 1;
    true
} else => {
    if to_y < from_y => {
        step_y = -1;
        true
    } else => {
        false
    }
};
let mut screens: int = 0;
let mut scan_x: int = from_x + step_x;
let mut scan_y: int = from_y + step_y;
while (same_file || same_rank) && (scan_x != to_x || scan_y != to_y) {
    let add_screen: bool = if bevy::Xiangqi::cell(scan_x, scan_y) != 0 => {
        screens = screens + 1;
        true
    } else => {
        false
    };
    scan_x = scan_x + step_x;
    scan_y = scan_y + step_y;
}

let mut valid_shape: bool = false;

let general_rule: bool = if abs_piece == 1 => {
    let palace_x: bool = to_x >= 3 && to_x <= 5;
    let palace_y: bool = if player == 1 => { to_y >= 7 && to_y <= 9 } else => { to_y >= 0 && to_y <= 2 };
    let one_step: bool = (abs_dx + abs_dy) == 1 && palace_x && palace_y;
    let flying: bool = same_file && target == (0 - player) && screens == 0;
    valid_shape = one_step || flying;
    true
} else => {
    false
};

let advisor_rule: bool = if abs_piece == 2 => {
    let palace_x: bool = to_x >= 3 && to_x <= 5;
    let palace_y: bool = if player == 1 => { to_y >= 7 && to_y <= 9 } else => { to_y >= 0 && to_y <= 2 };
    valid_shape = abs_dx == 1 && abs_dy == 1 && palace_x && palace_y;
    true
} else => {
    false
};

let elephant_rule: bool = if abs_piece == 3 => {
    let river_ok: bool = if player == 1 => { to_y >= 5 } else => { to_y <= 4 };
    let eye_clear: bool = bevy::Xiangqi::cell(from_x + dx_raw / 2, from_y + dy_raw / 2) == 0;
    valid_shape = abs_dx == 2 && abs_dy == 2 && river_ok && eye_clear;
    true
} else => {
    false
};

let horse_rule: bool = if abs_piece == 4 => {
    let mut leg_x: int = from_x;
    let mut leg_y: int = from_y;
    let leg_file: bool = if abs_dx == 2 => {
        leg_x = from_x + dx_raw / 2;
        true
    } else => {
        false
    };
    let leg_rank: bool = if abs_dy == 2 => {
        leg_y = from_y + dy_raw / 2;
        true
    } else => {
        false
    };
    valid_shape = ((abs_dx == 2 && abs_dy == 1) || (abs_dx == 1 && abs_dy == 2))
        && bevy::Xiangqi::cell(leg_x, leg_y) == 0;
    true
} else => {
    false
};

let chariot_rule: bool = if abs_piece == 5 => {
    valid_shape = (same_file || same_rank) && screens == 0 && (abs_dx + abs_dy) > 0;
    true
} else => {
    false
};

let cannon_rule: bool = if abs_piece == 6 => {
    let line: bool = same_file || same_rank;
    let quiet_move: bool = target == 0 && screens == 0;
    let capture_move: bool = target * player < 0 && screens == 1;
    valid_shape = line && (quiet_move || capture_move) && (abs_dx + abs_dy) > 0;
    true
} else => {
    false
};

let soldier_rule: bool = if abs_piece == 7 => {
    let red_forward: bool = dy_raw == -1;
    let black_forward: bool = dy_raw == 1;
    let same_file_step: bool = dx_raw == 0;
    let same_rank_step: bool = dy_raw == 0;
    let side_step: bool = abs_dx == 1;
    let red_crossed: bool = from_y <= 4;
    let black_crossed: bool = from_y >= 5;
    let red_rule: bool = if player == 1 => {
        let red_straight: bool = if same_file_step => {
            let red_forward_mark: bool = if red_forward => {
                valid_shape = true;
                true
            } else => {
                false
            };
            true
        } else => {
            false
        };
        let red_side: bool = if red_crossed => {
            let red_side_file: bool = if side_step => {
                let red_side_rank: bool = if same_rank_step => {
                    valid_shape = true;
                    true
                } else => {
                    false
                };
                true
            } else => {
                false
            };
            true
        } else => {
            false
        };
        true
    } else => {
        false
    };
    let black_rule: bool = if player == -1 => {
        let black_straight: bool = if same_file_step => {
            let black_forward_mark: bool = if black_forward => {
                valid_shape = true;
                true
            } else => {
                false
            };
            true
        } else => {
            false
        };
        let black_side: bool = if black_crossed => {
            let black_side_file: bool = if side_step => {
                let black_side_rank: bool = if same_rank_step => {
                    valid_shape = true;
                    true
                } else => {
                    false
                };
                true
            } else => {
                false
            };
            true
        } else => {
            false
        };
        true
    } else => {
        false
    };
    true
} else => {
    false
};

let base_ok: bool = in_bounds && own_piece;
let destination_ok: bool = target_ok && valid_shape;
let mut legal: bool = base_ok && destination_ok;
let moved: bool = if legal => {
    let cleared: bool = bevy::Xiangqi::set_cell(from_x, from_y, 0);
    let written: bool = bevy::Xiangqi::set_cell(to_x, to_y, piece);
    true
} else => {
    false
};

let mut red_general_x: int = -1;
let mut red_general_y: int = -1;
let mut black_general_x: int = -1;
let mut black_general_y: int = -1;
let mut board_y: int = 0;
while board_y < height {
    let mut board_x: int = 0;
    while board_x < width {
        let cell: int = bevy::Xiangqi::cell(board_x, board_y);
        let red_mark: bool = if cell == 1 => {
            red_general_x = board_x;
            red_general_y = board_y;
            true
        } else => {
            false
        };
        let black_mark: bool = if cell == -1 => {
            black_general_x = board_x;
            black_general_y = board_y;
            true
        } else => {
            false
        };
        board_x = board_x + 1;
    }
    board_y = board_y + 1;
}

let mut face_blockers: int = 0;
let mut face_scan_y: int = black_general_y + 1;
while legal && red_general_x >= 0 && black_general_x >= 0 && red_general_x == black_general_x
    && face_scan_y < red_general_y {
    let face_count: bool = if bevy::Xiangqi::cell(red_general_x, face_scan_y) != 0 => {
        face_blockers = face_blockers + 1;
        true
    } else => {
        false
    };
    face_scan_y = face_scan_y + 1;
}

let reverted: bool = if legal && red_general_x >= 0 && black_general_x >= 0
    && red_general_x == black_general_x && face_blockers == 0 => {
    let restore_from: bool = bevy::Xiangqi::set_cell(from_x, from_y, piece);
    let restore_to: bool = bevy::Xiangqi::set_cell(to_x, to_y, target);
    legal = false;
    true
} else => {
    false
};

let winner: int = if legal && target == (0 - player) => { player } else => { 0 };
let published: bool = bevy::Xiangqi::set_move_result(legal, winner);
legal;
