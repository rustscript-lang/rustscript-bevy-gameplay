use bevy;

fn abs_int(value: int) -> int {
    if value < 0 => { -value } else => { value }
}

fn in_bounds(x: int, y: int) -> bool {
    x >= 0 && x < 9 && y >= 0 && y < 10
}

fn in_palace(side: int, x: int, y: int) -> bool {
    x >= 3 && x <= 5 && if side == 1 => { y >= 7 && y <= 9 } else => { y >= 0 && y <= 2 }
}

fn count_between(fx: int, fy: int, tx: int, ty: int) -> int {
    let mut count = 0;
    if fx == tx || fy == ty {
        let step_x = if tx > fx => { 1 } else => { if tx < fx => { -1 } else => { 0 } };
        let step_y = if ty > fy => { 1 } else => { if ty < fy => { -1 } else => { 0 } };
        let mut x = fx + step_x;
        let mut y = fy + step_y;
        while x != tx || y != ty {
            if bevy::Xiangqi::cell(x, y) != 0 {
                count = count + 1;
            }
            x = x + step_x;
            y = y + step_y;
        }
    }
    count
}

fn pseudo_legal(side: int, fx: int, fy: int, tx: int, ty: int) -> bool {
    let mut valid = false;
    if in_bounds(fx, fy) && in_bounds(tx, ty) && (fx != tx || fy != ty) {
        let piece: int = bevy::Xiangqi::cell(fx, fy);
        let target: int = bevy::Xiangqi::cell(tx, ty);
        if piece * side > 0 && target * side <= 0 {
            let kind = abs_int(piece);
            let dx = tx - fx;
            let dy = ty - fy;
            let ax = abs_int(dx);
            let ay = abs_int(dy);
            if kind == 1 {
                let step = ax + ay == 1 && in_palace(side, tx, ty);
                let flying = fx == tx && target == -side && count_between(fx, fy, tx, ty) == 0;
                valid = step || flying;
            } else {
                if kind == 2 {
                    valid = ax == 1 && ay == 1 && in_palace(side, tx, ty);
                } else {
                    if kind == 3 {
                        let own_half = if side == 1 => { ty >= 5 } else => { ty <= 4 };
                        valid = ax == 2 && ay == 2 && own_half &&
                            bevy::Xiangqi::cell(fx + dx / 2, fy + dy / 2) == 0;
                    } else {
                        if kind == 4 {
                            let leg_x = if ax == 2 => { fx + dx / 2 } else => { fx };
                            let leg_y = if ay == 2 => { fy + dy / 2 } else => { fy };
                            valid = ((ax == 2 && ay == 1) || (ax == 1 && ay == 2)) &&
                                bevy::Xiangqi::cell(leg_x, leg_y) == 0;
                        } else {
                            if kind == 5 {
                                valid = (fx == tx || fy == ty) && count_between(fx, fy, tx, ty) == 0;
                            } else {
                                if kind == 6 {
                                    let line = fx == tx || fy == ty;
                                    let screens = count_between(fx, fy, tx, ty);
                                    valid = line && if target == 0 => { screens == 0 } else => { screens == 1 };
                                } else {
                                    if kind == 7 {
                                        let forward = if side == 1 => { dy == -1 } else => { dy == 1 };
                                        let crossed = if side == 1 => { fy <= 4 } else => { fy >= 5 };
                                        valid = (dx == 0 && forward) || (crossed && ay == 0 && ax == 1);
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
    valid
}

fn find_general(side: int) -> [int] {
    let mut result: [int] = [-1, -1];
    let mut y = 0;
    while y < 10 {
        let mut x = 0;
        while x < 9 {
            if bevy::Xiangqi::cell(x, y) == side {
                result[0] = x;
                result[1] = y;
            }
            x = x + 1;
        }
        y = y + 1;
    }
    result
}

fn is_attacked(x: int, y: int, by_side: int) -> bool {
    let mut attacked = false;
    let mut fy = 0;
    while !attacked && fy < 10 {
        let mut fx = 0;
        while !attacked && fx < 9 {
            if bevy::Xiangqi::cell(fx, fy) * by_side > 0 && pseudo_legal(by_side, fx, fy, x, y) {
                attacked = true;
            }
            fx = fx + 1;
        }
        fy = fy + 1;
    }
    attacked
}

fn legal_after_trial(side: int, fx: int, fy: int, tx: int, ty: int) -> bool {
    let mut legal = pseudo_legal(side, fx, fy, tx, ty);
    if legal {
        let piece: int = bevy::Xiangqi::cell(fx, fy);
        let target: int = bevy::Xiangqi::cell(tx, ty);
        bevy::Xiangqi::set_cell(fx, fy, 0);
        bevy::Xiangqi::set_cell(tx, ty, piece);
        let general = find_general(side);
        let gx = general[0].copy();
        let gy = general[1].copy();
        legal = gx >= 0 && !is_attacked(gx, gy, -side);
        bevy::Xiangqi::set_cell(fx, fy, piece);
        bevy::Xiangqi::set_cell(tx, ty, target);
    }
    legal
}

fn has_legal_move(side: int) -> bool {
    let mut found = false;
    let mut fy = 0;
    while !found && fy < 10 {
        let mut fx = 0;
        while !found && fx < 9 {
            if bevy::Xiangqi::cell(fx, fy) * side > 0 {
                let mut ty = 0;
                while !found && ty < 10 {
                    let mut tx = 0;
                    while !found && tx < 9 {
                        if legal_after_trial(side, fx, fy, tx, ty) {
                            found = true;
                        }
                        tx = tx + 1;
                    }
                    ty = ty + 1;
                }
            }
            fx = fx + 1;
        }
        fy = fy + 1;
    }
    found
}

let legal = (player == 1 || player == -1) && legal_after_trial(player, from_x, from_y, to_x, to_y);
let mut winner = 0;
if legal {
    let piece: int = bevy::Xiangqi::cell(from_x, from_y);
    let target: int = bevy::Xiangqi::cell(to_x, to_y);
    bevy::Xiangqi::set_cell(from_x, from_y, 0);
    bevy::Xiangqi::set_cell(to_x, to_y, piece);
    if target == -player || !has_legal_move(-player) {
        winner = player;
    }
}

bevy::Xiangqi::set_move_result(legal, winner);
legal;
